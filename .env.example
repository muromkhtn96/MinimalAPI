# MinimalAPI - Environment Variables Template
# Copy this file to .env and update with your values

# Database Password (REQUIRED for production)
DB_PASSWORD=your_secure_password_here

# Database User (optional, default: postgres)
# DB_USER=postgres

# CORS Allowed Origins (production)
# Separate multiple origins with comma
ALLOWED_ORIGINS=http://localhost:8080

# Example for multiple domains:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
